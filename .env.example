# Supabase project URL (Supabase Dashboard → Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (Supabase Dashboard → Project Settings → API → anon/public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry DSN for error tracking — optional, skipped if absent (Sentry Dashboard → Project Settings → Client Keys)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
